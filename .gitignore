# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# project working docs & reference material — local only, NOT deployed.
# Convention: any root file/dir prefixed with "_" is metadata (plans, matrices,
# mockups, source .docx). Only shipped files belong here.
/_*
# ...except the content spec itself — that one deliverable stays tracked, while
# its heavy reference/ (mockups, source .docx, clips) remains local.
!/_content/
/_content/*
!/_content/website-content-spec.md

# source / reference material — not part of the deployed app
/Trot Videos/
/transland-transportation-logistics-theme/
/_ref/
# client .docx source, extracted docx images, and the licensed Transland theme
# (~54MB, and the theme is third-party licensed — assets get copied into /public
# as they're used, the raw material stays local)
/_references/

# scraper + rebuild tooling — reference only, not deployed
/output/
/.scraper-venv/
scraper.py
build_plan.py
_rebuild-plan.json
_rebuild-plan.md

# tooling / local
/.claude/
/.vscode/
/.codegraph/
/plans/
*.original.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
