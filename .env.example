# Video hosting base URL.
# Unset (default) = serve from local /public/videos — works now, free.
# Later: move 348MB of clips to Cloudflare R2 and set this to the public
# bucket URL. Nothing else changes — all paths route through src/lib/videos.ts.
#
#   NEXT_PUBLIC_VIDEO_BASE=https://pub-xxxxxxxx.r2.dev
NEXT_PUBLIC_VIDEO_BASE=
